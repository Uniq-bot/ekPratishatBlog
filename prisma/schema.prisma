generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  password  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  posts     BlogPost[]
}

model BlogPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String?
  content     Json
  coverImage  String?
  status      PostStatus @default(DRAFT)
  authorID    String
  author      User       @relation(fields: [authorID], references: [id])
  categoryID  String
  category    Category   @relation(fields: [categoryID], references: [id])
  tags        Tag[]      @relation("PostTags")
  viewCount   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  blogViews   BlogViews[]
  isToggled  Boolean    @default(false)
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlogViews {
  id         String   @id @default(cuid())
  blogPostId String
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id])
  sessionId  String
  createdAt  DateTime @default(now())

  @@unique([blogPostId, sessionId])
  @@index([blogPostId])
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  posts       BlogPost[]
}

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt @default(now())
  blogPosts BlogPost[] @relation("PostTags")
}

model Advertisement{
  id String @id @default(cuid())
  AdTitle String
  AdDescription String
  AdPoster String
  AdLink String
  AdSponsorName String
  isAdRunning Boolean @default(true)
  AdType AdType @default(BANNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AdType{
  BANNER
  ASIDE
  POPUP
}
