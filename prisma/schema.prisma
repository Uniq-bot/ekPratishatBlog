generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  password  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  posts     BlogPost[]
}

model BlogPost {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  authorID    String
  categoryID  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  coverImage  String?
  status      PostStatus  @default(DRAFT)
  viewCount   Int         @default(0)
  content     Json
  description String?
  isToggled   Boolean     @default(false)
  author      User        @relation(fields: [authorID], references: [id])
  category    Category    @relation(fields: [categoryID], references: [id])
  blogViews   BlogViews[]
  tags        Tag[]       @relation("PostTags")
}

model BlogViews {
  id         String   @id @default(cuid())
  blogPostId String
  sessionId  String
  createdAt  DateTime @default(now())
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id])

  @@unique([blogPostId, sessionId])
  @@index([blogPostId])
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  createdAt   DateTime   @default(now())
  description String?
  updatedAt   DateTime   @updatedAt
  posts       BlogPost[]
}

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt
  blogPosts BlogPost[] @relation("PostTags")
}

model Advertisement {
  id            String   @id @default(cuid())
  AdTitle       String
  AdDescription String
  AdPoster      String
  AdLink        String
  AdSponsorName String
  AdType        AdType   @default(BANNER)
  isAdRunning   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AdType {
  BANNER
  ASIDE
  POPUP
}
