generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Language {
  en
  ne
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  ONBOARDING
}

enum AdType {
  BANNER
  ASIDE
  POPUP
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  password  String

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  posts      BlogPost[]
}

model BlogPost {
  id          String      @id @default(cuid())
  slug        String      @unique

  authorID    String
  categoryID  String?

  coverImage  String?
  status      PostStatus  @default(DRAFT)
  viewCount   Int         @default(0)
  isToggled   Boolean     @default(false)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  author       User       @relation(fields: [authorID], references: [id])
  category     Category?  @relation(fields: [categoryID], references: [id])

  translations BlogTranslation[]

  tagLinks     TagOnPost[]

  blogViews    BlogViews[]
  comments     BlogComment[]

  @@index([status, createdAt])
  @@index([status, viewCount, createdAt])
  @@index([isToggled, status])
  @@index([categoryID])
}

model BlogTranslation {
  id              String   @id @default(cuid())

  blogPostId      String
  blogPost        BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  language        Language

  title           String
  description     String?
  content         Json

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([blogPostId, language])
}

model Category {
  id          String    @id @default(cuid())

  slug        String    @unique

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  posts        BlogPost[]
  translations CategoryTranslation[]
}

model CategoryTranslation {
  id            String    @id @default(cuid())

  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  language      Language

  name          String
  description   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([categoryId, language])
}

model Tag {
  id          String   @id @default(cuid())

  slug        String   @unique

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  blogPosts   TagOnPost[]

  translations TagTranslation[]
}

model TagTranslation {
  id          String   @id @default(cuid())

  tagId       String
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  language    Language

  name        String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tagId, language])
}

model TagOnPost {
  blogPostId  String
  tagId        String

  blogPost     BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  tag          Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogPostId, tagId])

  @@index([tagId])
}

model BlogComment {
  id            String   @id @default(cuid())

  blogPostId    String
  blogPost      BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  userEmail     String
  userName      String
  userImage     String
  commentText   String

  createdAt     DateTime @default(now())

  @@index([blogPostId])
}

model BlogViews {
  id            String   @id @default(cuid())

  blogPostId    String
  sessionId     String

  createdAt     DateTime @default(now())

  blogPost      BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, sessionId])
  @@index([blogPostId])
}

model Advertisement {
  id              String   @id @default(cuid())

  AdTitle         String
  AdDescription   String
  AdPoster        String
  AdLink          String
  AdSponsorName   String

  AdType          AdType   @default(BANNER)
  isAdRunning     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())

  email       String   @unique

  createdAt   DateTime @default(now())
}